---
import { siteConfig } from "../config";
import "../styles/barron.css";

const showCareerSections = false;
const showProjects = false;
---

<!DOCTYPE HTML>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={siteConfig.description} />
    <title>Xi Lin丨JHU</title>
  </head>
  <body>
    <table class="page-table"><tbody>
      <tr>
        <td>
          <table class="page-table"><tbody>
            <tr>
              <td class="intro-cell">
                <p class="name">{siteConfig.name}</p>
                <p>
                  I am a <strong>WAM Intern at Yinwang</strong> and an <strong>M.S. student in Robotics</strong> at <a href="https://www.jhu.edu/">Johns Hopkins University</a>.
                </p>
                <p>
                  I am currently working on <strong>world-action models for dexterous-hand manipulation</strong>, especially WAM pretraining, with Dr. <a href="https://scholar.google.com.hk/citations?user=A1__8cUAAAAJ&hl=zh-CN&oi=sra">Zhaowen Li</a> and Dr. <a href="https://zhirui-gao.github.io/">Zhirui Gao</a>. Previously, I worked on VLN at <strong>JD Explore Academy</strong> with Dr. Lin Zhao, robot dynamics and terradynamics at JHU with Prof. <a href="https://me.jhu.edu/faculty/chen-li/">Chen Li</a>, and completed my undergraduate thesis at <a href="https://www.dlut.edu.cn/">Dalian University of Technology</a> under Prof. <a href="https://faculty.dlut.edu.cn/2005011026/en/index.htm">Yan Zhuang</a>.
                </p>
                <p>
                  I am currently looking for <strong>on-site RA opportunities from Summer 2026 to Winter 2026</strong>. I am also open to research collaborations in any form, including remote collaboration, and happy to chat anytime.
                </p>
                <p class="link-line">
                  <a href={`mailto:${siteConfig.social.email}`}>Email</a> &nbsp;/&nbsp;
                  <a href={siteConfig.social.cv}>CV</a> &nbsp;/&nbsp;
                  <a href={siteConfig.social.scholar}>Scholar</a>
                </p>
              </td>
            </tr>
          </tbody></table>

          <table class="page-table"><tbody>
            <tr>
              <td class="section-cell">
                <h2>Research</h2>
                <p>
                  My recent work mainly focuses on <strong>world-action models for embodied agents</strong>, with an emphasis on dexterous-hand manipulation and WAM pretraining.
                </p>
                <ul class="compact-list">
                  <li><strong>WAM for dexterous manipulation:</strong> pretraining world-action models for dexterous-hand interaction and control.</li>
                  <li><strong>VLN / ObjectNav:</strong> prior work on long-horizon instruction following and real-robot deployment.</li>
                  <li><strong>Robot control:</strong> earlier experience in WBC, retargeting, locomotion, and sim-to-real transfer.</li>
                </ul>
              </td>
            </tr>
          </tbody></table>

          <table class="entry-table"><tbody>
            {siteConfig.publications.map((publication) => (
              <tr>
                <td class="thumb-cell">
                  <a href={publication.link}>
                    <img class="thumb-image" src={publication.image} alt={publication.name} />
                  </a>
                </td>
                <td class="entry-cell">
                  <a href={publication.link}>
                    <span class="papertitle">{publication.name}</span>
                  </a>
                  <br />
                  <span set:html={publication.authors}></span>
                  <br />
                  <em><strong>{publication.venue}</strong>{publication.status && ` | ${publication.status}`}</em>
                  <br />
                  <a href={publication.link}>project page</a>
                  {publication.pdf && <span> / <a href={publication.pdf}>pdf</a></span>}
                  <p>{publication.description}</p>
                </td>
              </tr>
            ))}
          </tbody></table>

          {showProjects && (
            <>
              <table class="page-table"><tbody>
                <tr>
                  <td class="section-cell">
                    <h2>Projects</h2>
                  </td>
                </tr>
              </tbody></table>

              <table class="entry-table"><tbody>
                {siteConfig.projects.map((project) => (
                  <tr>
                    <td class="thumb-cell">
                      <a href={project.link}>
                        <img class="thumb-image" src={project.image} alt={project.name} />
                      </a>
                    </td>
                    <td class="entry-cell">
                      <a href={project.link}>
                        <span class="papertitle">{project.name}</span>
                      </a>
                      <br />
                      <em>{project.subtitle}</em>
                      <br />
                      <a href={project.link}>project page</a>
                      <p>{project.description}</p>
                    </td>
                  </tr>
                ))}
              </tbody></table>
            </>
          )}

          {showCareerSections && (
            <table class="page-table"><tbody>
              <tr>
                <td class="section-cell">
                  <h2>Experience</h2>
                  {siteConfig.experience.map((exp) => (
                    <table class="mini-entry"><tbody>
                      <tr>
                        <td class="mini-logo-cell">
                          <div class="mini-logo">
                            <img src={exp.logoImage} alt={`${exp.company} logo`} />
                          </div>
                        </td>
                        <td class="mini-content">
                          <p class="mini-title">
                            <strong>{exp.title}</strong>, <strong>{exp.company}</strong>
                          </p>
                          <p class="mini-date"><em>{exp.dateRange}</em></p>
                          <ul class="mini-bullets">
                            {exp.bullets.slice(0, 2).map((bullet) => <li>{bullet}</li>)}
                          </ul>
                        </td>
                      </tr>
                    </tbody></table>
                  ))}
                </td>
              </tr>
            </tbody></table>
          )}

          {showCareerSections && (
            <table class="page-table"><tbody>
              <tr>
                <td class="section-cell">
                  <h2>Education</h2>
                  {siteConfig.education.map((edu) => (
                    <table class="mini-entry"><tbody>
                      <tr>
                        <td class="mini-logo-cell">
                          <div class="mini-logo">
                            <img src={edu.logoImage} alt={`${edu.school} logo`} />
                          </div>
                        </td>
                        <td class="mini-content">
                          <p class="mini-title">
                            <strong>{edu.school}</strong>, {edu.degree}
                          </p>
                          <p class="mini-date"><em>{edu.dateRange}</em></p>
                          <ul class="mini-bullets">
                            {edu.achievements.map((achievement) => <li>{achievement}</li>)}
                          </ul>
                        </td>
                      </tr>
                    </tbody></table>
                  ))}
                </td>
              </tr>
            </tbody></table>
          )}
        </td>
      </tr>
    </tbody></table>
  </body>
</html>
