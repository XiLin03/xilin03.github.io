---
import { siteConfig } from "../config";
import "../styles/global.css";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={siteConfig.description} />
    <title>{siteConfig.name} - {siteConfig.title}</title>
  </head>
  <body class="bg-white text-slate-900">
    <main class="mx-auto max-w-5xl px-5 py-8 sm:px-6 md:py-12">
      <header class="mb-12 border-b border-slate-200 pb-8">
        <div class="flex flex-col gap-5 md:flex-row md:items-end md:justify-between">
          <div>
            <h1 class="text-4xl font-semibold tracking-tight text-slate-950 sm:text-5xl">
              {siteConfig.name}
            </h1>
            <p class="mt-2 text-lg text-slate-700">{siteConfig.title}</p>
            <p class="mt-3 max-w-3xl text-base leading-7 text-slate-700">
              Research Interests: WAM | VLA | VLN | WBC. Currently seeking remote research internship opportunities.
            </p>
          </div>
          <nav class="flex flex-wrap gap-x-4 gap-y-2 text-sm text-blue-700">
            <a class="hover:underline" href="#about">About</a>
            <a class="hover:underline" href="#publications">Publications</a>
            <a class="hover:underline" href="#projects">Projects</a>
            <a class="hover:underline" href="#experience">Experience</a>
            <a class="hover:underline" href="#education">Education</a>
          </nav>
        </div>

        <div class="mt-5 flex flex-wrap gap-x-4 gap-y-2 text-sm">
          <a class="text-blue-700 hover:underline" href={`mailto:${siteConfig.social.email}`}>
            {siteConfig.social.email}
          </a>
          <a class="text-blue-700 hover:underline" href={`mailto:${siteConfig.social.emailSecondary}`}>
            {siteConfig.social.emailSecondary}
          </a>
          <a class="text-blue-700 hover:underline" href={siteConfig.social.github} target="_blank" rel="noopener noreferrer">
            GitHub
          </a>
          <a class="text-blue-700 hover:underline" href={siteConfig.social.linkedin} target="_blank" rel="noopener noreferrer">
            LinkedIn
          </a>
          <a class="text-blue-700 hover:underline" href={siteConfig.social.cv}>CV</a>
          <a class="text-blue-700 hover:underline" href={siteConfig.social.cvCn}>CV (CN)</a>
          <a class="text-blue-700 hover:underline" href={siteConfig.social.careerSite} target="_blank" rel="noopener noreferrer">
            Portfolio / work site
          </a>
        </div>
      </header>

      <section id="about" class="section-block">
        <h2 class="section-title">About</h2>
        <div class="space-y-4 text-[15px] leading-7 text-slate-700">
          {siteConfig.about.map((paragraph) => <p>{paragraph}</p>)}
        </div>
        <div class="mt-4 flex flex-wrap gap-2">
          {siteConfig.aboutTags.map((tag) => (
            <span class="rounded border border-slate-200 bg-slate-50 px-2.5 py-1 text-xs text-slate-700">
              {tag}
            </span>
          ))}
        </div>
      </section>

      <section id="publications" class="section-block">
        <h2 class="section-title">Publications</h2>
        <div class="space-y-8">
          {siteConfig.publications.map((publication) => (
            <article class="grid gap-4 sm:grid-cols-[180px_minmax(0,1fr)]">
              <a href={publication.link} class="block overflow-hidden rounded border border-slate-200 bg-slate-50 p-2">
                <img src={publication.image} alt={publication.name} class="aspect-[16/10] h-auto w-full object-contain" />
              </a>
              <div>
                <p class="text-xs font-medium text-blue-700">{publication.subtitle}</p>
                <h3 class="mt-1 text-lg font-semibold leading-snug text-slate-950">
                  <a href={publication.link} class="hover:text-blue-700">{publication.name}</a>
                </h3>
                <p class="mt-2 text-[15px] leading-7 text-slate-700">{publication.description}</p>
                <div class="mt-2 flex flex-wrap gap-x-3 gap-y-1 text-sm">
                  <a class="text-blue-700 hover:underline" href={publication.link}>View details</a>
                  {publication.pdf && <a class="text-blue-700 hover:underline" href={publication.pdf}>Download PDF</a>}
                </div>
              </div>
            </article>
          ))}
        </div>
      </section>

      <section id="projects" class="section-block">
        <h2 class="section-title">Projects</h2>
        <div class="space-y-6">
          {siteConfig.projects.map((project) => (
            <article class="grid gap-4 sm:grid-cols-[180px_minmax(0,1fr)]">
              <a href={project.link} class="block overflow-hidden rounded border border-slate-200 bg-slate-50 p-2">
                <img src={project.image} alt={project.name} class="aspect-[16/10] h-auto w-full object-contain" />
              </a>
              <div>
                <p class="text-xs font-medium text-blue-700">{project.subtitle}</p>
                <h3 class="mt-1 text-lg font-semibold leading-snug text-slate-950">
                  <a href={project.link} class="hover:text-blue-700">{project.name}</a>
                </h3>
                <p class="mt-2 text-[15px] leading-7 text-slate-700">{project.description}</p>
                <a class="mt-2 inline-block text-sm text-blue-700 hover:underline" href={project.link}>View project</a>
              </div>
            </article>
          ))}
        </div>
      </section>

      <section id="experience" class="section-block">
        <h2 class="section-title">Experience</h2>
        <div class="space-y-5">
          {siteConfig.experience.map((exp) => (
            <article>
              <div class="flex flex-col gap-1 sm:flex-row sm:items-baseline sm:justify-between">
                <h3 class="font-semibold text-slate-950">{exp.title}, {exp.company}</h3>
                <p class="text-sm text-slate-500">{exp.dateRange}</p>
              </div>
              <ul class="mt-2 list-disc space-y-1 pl-5 text-[15px] leading-7 text-slate-700">
                {exp.bullets.map((bullet) => <li>{bullet}</li>)}
              </ul>
            </article>
          ))}
        </div>
      </section>

      <section id="education" class="section-block">
        <h2 class="section-title">Education</h2>
        <div class="space-y-5">
          {siteConfig.education.map((edu) => (
            <article>
              <div class="flex flex-col gap-1 sm:flex-row sm:items-baseline sm:justify-between">
                <h3 class="font-semibold text-slate-950">{edu.degree}, {edu.school}</h3>
                <p class="text-sm text-slate-500">{edu.dateRange}</p>
              </div>
              <ul class="mt-2 list-disc space-y-1 pl-5 text-[15px] leading-7 text-slate-700">
                {edu.achievements.map((achievement) => <li>{achievement}</li>)}
              </ul>
            </article>
          ))}
        </div>
      </section>
    </main>
  </body>
</html>

<style>
  :global(html) {
    scroll-behavior: smooth;
  }

  .section-block {
    margin-top: 2.75rem;
  }

  .section-title {
    margin-bottom: 1rem;
    border-bottom: 1px solid rgb(226 232 240);
    padding-bottom: 0.35rem;
    font-size: 1.35rem;
    font-weight: 650;
    color: rgb(2 6 23);
  }
</style>
