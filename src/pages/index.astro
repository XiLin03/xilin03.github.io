---
import { siteConfig } from "../config";
import "../styles/barron.css";
---

<!DOCTYPE HTML>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={siteConfig.description} />
    <title>{siteConfig.name} - {siteConfig.title}</title>
  </head>
  <body>
    <table class="page-table"><tbody>
      <tr>
        <td>
          <table class="page-table"><tbody>
            <tr>
              <td class="intro-cell">
                <p class="name">{siteConfig.name}</p>
                <p>
                  I am an M.S. student in Robotics at Johns Hopkins University. My recent work focuses on embodied AI systems that connect real-robot deployment, long-horizon reasoning, and control-aware decision making.
                </p>
                <p>
                  I started from whole-body control and locomotion, then moved into vision-language navigation and world-model-oriented embodied systems. I am currently interested in WAM, VLA, VLN, and WBC, and I am seeking remote research internship opportunities.
                </p>
                <p class="link-line">
                  <a href={`mailto:${siteConfig.social.email}`}>Email</a> &nbsp;/&nbsp;
                  <a href={`mailto:${siteConfig.social.emailSecondary}`}>Outlook</a> &nbsp;/&nbsp;
                  <a href={siteConfig.social.cv}>CV</a> &nbsp;/&nbsp;
                  <a href={siteConfig.social.cvCn}>CV (CN)</a> &nbsp;/&nbsp;
                  <a href={siteConfig.social.github}>Github</a> &nbsp;/&nbsp;
                  <a href={siteConfig.social.linkedin}>LinkedIn</a> &nbsp;/&nbsp;
                  <a href={siteConfig.social.careerSite}>Portfolio</a>
                </p>
              </td>
            </tr>
          </tbody></table>

          <table class="page-table"><tbody>
            <tr>
              <td class="section-cell">
                <h2>Research</h2>
                <p>
                  My research interests include world/action models, vision-language action and navigation, and robot control. I am especially interested in embodied systems that can reason over long horizons while remaining deployable on real robots.
                </p>
              </td>
            </tr>
          </tbody></table>

          <table class="entry-table"><tbody>
            {siteConfig.publications.map((publication) => (
              <tr>
                <td class="thumb-cell">
                  <a href={publication.link}>
                    <img class="thumb-image" src={publication.image} alt={publication.name} />
                  </a>
                </td>
                <td class="entry-cell">
                  <a href={publication.link}>
                    <span class="papertitle">{publication.name}</span>
                  </a>
                  <br />
                  <strong>Xi Lin</strong>
                  <br />
                  <em>{publication.subtitle}</em>
                  <br />
                  <a href={publication.link}>project page</a>
                  {publication.pdf && <span> / <a href={publication.pdf}>pdf</a></span>}
                  <p>{publication.description}</p>
                </td>
              </tr>
            ))}
          </tbody></table>

          <table class="page-table"><tbody>
            <tr>
              <td class="section-cell">
                <h2>Projects</h2>
              </td>
            </tr>
          </tbody></table>

          <table class="entry-table"><tbody>
            {siteConfig.projects.map((project) => (
              <tr>
                <td class="thumb-cell">
                  <a href={project.link}>
                    <img class="thumb-image" src={project.image} alt={project.name} />
                  </a>
                </td>
                <td class="entry-cell">
                  <a href={project.link}>
                    <span class="papertitle">{project.name}</span>
                  </a>
                  <br />
                  <em>{project.subtitle}</em>
                  <br />
                  <a href={project.link}>project page</a>
                  <p>{project.description}</p>
                </td>
              </tr>
            ))}
          </tbody></table>

          <table class="page-table"><tbody>
            <tr>
              <td class="section-cell">
                <h2>Experience</h2>
                {siteConfig.experience.map((exp) => (
                  <p>
                    <strong>{exp.title}</strong>, {exp.company}. <em>{exp.dateRange}</em>
                    <br />
                    {exp.bullets[0]}
                  </p>
                ))}
              </td>
            </tr>
          </tbody></table>

          <table class="page-table"><tbody>
            <tr>
              <td class="section-cell">
                <h2>Education</h2>
                {siteConfig.education.map((edu) => (
                  <p>
                    <strong>{edu.school}</strong>, {edu.degree}. <em>{edu.dateRange}</em>
                    <br />
                    {edu.achievements.join(" ")}
                  </p>
                ))}
              </td>
            </tr>
          </tbody></table>
        </td>
      </tr>
    </tbody></table>
  </body>
</html>
