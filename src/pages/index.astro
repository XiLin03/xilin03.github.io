---
import { siteConfig } from "../config";
import "../styles/barron.css";
---

<!DOCTYPE HTML>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={siteConfig.description} />
    <title>{siteConfig.name} - {siteConfig.title}</title>
  </head>
  <body>
    <table class="page-table"><tbody>
      <tr>
        <td>
          <table class="page-table"><tbody>
            <tr>
              <td class="intro-cell">
                <p class="name">{siteConfig.name}</p>
                <p>
                  I am an <strong>M.S. student in Robotics</strong> at <a href="https://www.jhu.edu/">Johns Hopkins University</a>, currently seeking <strong>remote research internship opportunities</strong> in embodied AI and robotics.
                </p>
                <p>
                  Previously, I worked on robot dynamics and terradynamics at JHU in collaboration with Prof. <a href="https://me.jhu.edu/faculty/chen-li/">Chen Li</a>, completed my undergraduate thesis at <a href="https://www.dlut.edu.cn/">Dalian University of Technology</a> under the supervision of Prof. <a href="https://faculty.dlut.edu.cn/2005011026/en/index.htm">Yan Zhuang</a>, and collaborated with Dr. Lin Zhao during my embodied navigation internship at <strong>JD.com</strong>.
                </p>
                <p class="link-line">
                  <a href={`mailto:${siteConfig.social.email}`}>Email</a> &nbsp;/&nbsp;
                  <a href={siteConfig.social.cv}>CV</a> &nbsp;/&nbsp;
                  <a href={siteConfig.social.careerSite}>Portfolio / work site</a>
                </p>
              </td>
            </tr>
          </tbody></table>

          <table class="page-table"><tbody>
            <tr>
              <td class="section-cell">
                <h2>Research</h2>
                <p>
                  My research interests center on <strong>deployable embodied intelligence</strong>: connecting perception, long-horizon reasoning, and robot control.
                </p>
                <ul class="compact-list">
                  <li><strong>WAM / VLA:</strong> world-action models and vision-language action systems.</li>
                  <li><strong>VLN / ObjectNav:</strong> long-horizon instruction following and real-robot deployment.</li>
                  <li><strong>WBC:</strong> whole-body control, retargeting, locomotion, and sim-to-real transfer.</li>
                </ul>
              </td>
            </tr>
          </tbody></table>

          <table class="entry-table"><tbody>
            {siteConfig.publications.map((publication) => (
              <tr>
                <td class="thumb-cell">
                  <a href={publication.link}>
                    <img class="thumb-image" src={publication.image} alt={publication.name} />
                  </a>
                </td>
                <td class="entry-cell">
                  <a href={publication.link}>
                    <span class="papertitle">{publication.name}</span>
                  </a>
                  <br />
                  <span set:html={publication.authors}></span>
                  <br />
                  <em><strong>{publication.venue}</strong>{publication.status && ` | ${publication.status}`}</em>
                  <br />
                  <a href={publication.link}>project page</a>
                  {publication.pdf && <span> / <a href={publication.pdf}>pdf</a></span>}
                  <p>{publication.description}</p>
                </td>
              </tr>
            ))}
          </tbody></table>

          <table class="page-table"><tbody>
            <tr>
              <td class="section-cell">
                <h2>Projects</h2>
              </td>
            </tr>
          </tbody></table>

          <table class="entry-table"><tbody>
            {siteConfig.projects.map((project) => (
              <tr>
                <td class="thumb-cell">
                  <a href={project.link}>
                    <img class="thumb-image" src={project.image} alt={project.name} />
                  </a>
                </td>
                <td class="entry-cell">
                  <a href={project.link}>
                    <span class="papertitle">{project.name}</span>
                  </a>
                  <br />
                  <em>{project.subtitle}</em>
                  <br />
                  <a href={project.link}>project page</a>
                  <p>{project.description}</p>
                </td>
              </tr>
            ))}
          </tbody></table>

          <table class="page-table"><tbody>
            <tr>
              <td class="section-cell">
                <h2>Experience</h2>
                {siteConfig.experience.map((exp) => (
                  <table class="mini-entry"><tbody>
                    <tr>
                      <td class="mini-logo-cell">
                        <div class="mini-logo">
                          <img src={exp.logoImage} alt={`${exp.company} logo`} />
                        </div>
                      </td>
                      <td class="mini-content">
                        <p class="mini-title">
                          <strong>{exp.title}</strong>, <strong>{exp.company}</strong>
                        </p>
                        <p class="mini-date"><em>{exp.dateRange}</em></p>
                        <ul class="mini-bullets">
                          {exp.bullets.slice(0, 2).map((bullet) => <li>{bullet}</li>)}
                        </ul>
                      </td>
                    </tr>
                  </tbody></table>
                ))}
              </td>
            </tr>
          </tbody></table>

          <table class="page-table"><tbody>
            <tr>
              <td class="section-cell">
                <h2>Education</h2>
                {siteConfig.education.map((edu) => (
                  <table class="mini-entry"><tbody>
                    <tr>
                      <td class="mini-logo-cell">
                        <div class="mini-logo">
                          <img src={edu.logoImage} alt={`${edu.school} logo`} />
                        </div>
                      </td>
                      <td class="mini-content">
                        <p class="mini-title">
                          <strong>{edu.school}</strong>, {edu.degree}
                        </p>
                        <p class="mini-date"><em>{edu.dateRange}</em></p>
                        <ul class="mini-bullets">
                          {edu.achievements.map((achievement) => <li>{achievement}</li>)}
                        </ul>
                      </td>
                    </tr>
                  </tbody></table>
                ))}
              </td>
            </tr>
          </tbody></table>
        </td>
      </tr>
    </tbody></table>
  </body>
</html>
