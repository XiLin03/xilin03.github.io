---
import { siteConfig } from "../config";
import "../styles/barron.css";
---

<!DOCTYPE HTML>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={siteConfig.description} />
    <title>{siteConfig.name} - {siteConfig.title}</title>
  </head>
  <body>
    <table class="page-table"><tbody>
      <tr>
        <td>
          <table class="page-table"><tbody>
            <tr>
              <td class="intro-cell">
                <p class="name">{siteConfig.name}</p>
                <p>
                  I am an <strong>M.S. student in Robotics</strong> at <a href="https://www.jhu.edu/">Johns Hopkins University</a>. My recent work focuses on <strong>embodied AI systems</strong> that connect real-robot deployment, long-horizon reasoning, and control-aware decision making.
                </p>
                <p>
                  I started from <strong>whole-body control and locomotion</strong>, then moved into <strong>vision-language navigation</strong> and <strong>world-model-oriented embodied systems</strong>. I am currently interested in <strong>WAM, VLA, VLN, and WBC</strong>, and I am seeking remote research internship opportunities.
                </p>
                <p class="link-line">
                  <a href={`mailto:${siteConfig.social.email}`}>Email</a> &nbsp;/&nbsp;
                  <a href={siteConfig.social.cv}>CV</a> &nbsp;/&nbsp;
                  <a href={siteConfig.social.careerSite}>Portfolio / work site</a>
                </p>
              </td>
            </tr>
          </tbody></table>

          <table class="page-table"><tbody>
            <tr>
              <td class="section-cell">
                <h2>Research</h2>
                <p>
                  My research interests include <strong>world/action models</strong>, <strong>vision-language action and navigation</strong>, and <strong>robot control</strong>. I am especially interested in embodied systems that can reason over long horizons while remaining deployable on real robots.
                </p>
                <ul class="compact-list">
                  <li><strong>World/action models:</strong> long-horizon embodied reasoning, planning, and deployment-aware decision making.</li>
                  <li><strong>Vision-language systems:</strong> VLN/ObjectNav, multimodal instruction following, and real-robot data collection.</li>
                  <li><strong>Robot control:</strong> whole-body control, retargeting, RL-based locomotion, and sim-to-real transfer.</li>
                </ul>
              </td>
            </tr>
          </tbody></table>

          <table class="entry-table"><tbody>
            {siteConfig.publications.map((publication) => (
              <tr>
                <td class="thumb-cell">
                  <a href={publication.link}>
                    <img class="thumb-image" src={publication.image} alt={publication.name} />
                  </a>
                </td>
                <td class="entry-cell">
                  <a href={publication.link}>
                    <span class="papertitle">{publication.name}</span>
                  </a>
                  <br />
                  <span set:html={publication.authors}></span>
                  <br />
                  <em><strong>{publication.venue}</strong>{publication.status && ` | ${publication.status}`}</em>
                  <br />
                  <a href={publication.link}>project page</a>
                  {publication.pdf && <span> / <a href={publication.pdf}>pdf</a></span>}
                  <p>{publication.description}</p>
                </td>
              </tr>
            ))}
          </tbody></table>

          <table class="page-table"><tbody>
            <tr>
              <td class="section-cell">
                <h2>Projects</h2>
              </td>
            </tr>
          </tbody></table>

          <table class="entry-table"><tbody>
            {siteConfig.projects.map((project) => (
              <tr>
                <td class="thumb-cell">
                  <a href={project.link}>
                    <img class="thumb-image" src={project.image} alt={project.name} />
                  </a>
                </td>
                <td class="entry-cell">
                  <a href={project.link}>
                    <span class="papertitle">{project.name}</span>
                  </a>
                  <br />
                  <em>{project.subtitle}</em>
                  <br />
                  <a href={project.link}>project page</a>
                  <p>{project.description}</p>
                </td>
              </tr>
            ))}
          </tbody></table>

          <table class="page-table"><tbody>
            <tr>
              <td class="section-cell">
                <h2>Experience</h2>
                {siteConfig.experience.map((exp) => (
                  <table class="mini-entry"><tbody>
                    <tr>
                      <td class="mini-logo-cell">
                        <div class="mini-logo">
                          <img src={exp.logoImage} alt={`${exp.company} logo`} />
                        </div>
                      </td>
                      <td class="mini-content">
                        <p class="mini-title">
                          <strong>{exp.title}</strong>, <strong>{exp.company}</strong>
                        </p>
                        <p class="mini-date"><em>{exp.dateRange}</em></p>
                        <ul class="mini-bullets">
                          {exp.bullets.slice(0, 2).map((bullet) => <li>{bullet}</li>)}
                        </ul>
                      </td>
                    </tr>
                  </tbody></table>
                ))}
              </td>
            </tr>
          </tbody></table>

          <table class="page-table"><tbody>
            <tr>
              <td class="section-cell">
                <h2>Education</h2>
                {siteConfig.education.map((edu) => (
                  <table class="mini-entry"><tbody>
                    <tr>
                      <td class="mini-logo-cell">
                        <div class="mini-logo">
                          <img src={edu.logoImage} alt={`${edu.school} logo`} />
                        </div>
                      </td>
                      <td class="mini-content">
                        <p class="mini-title">
                          <strong>{edu.school}</strong>, {edu.degree}
                        </p>
                        <p class="mini-date"><em>{edu.dateRange}</em></p>
                        <ul class="mini-bullets">
                          {edu.achievements.map((achievement) => <li>{achievement}</li>)}
                        </ul>
                      </td>
                    </tr>
                  </tbody></table>
                ))}
              </td>
            </tr>
          </tbody></table>
        </td>
      </tr>
    </tbody></table>
  </body>
</html>
