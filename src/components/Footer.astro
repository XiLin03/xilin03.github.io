---
import { siteConfig } from "../config";
---

<footer id="contact" class="relative bg-gray-50 border-t border-gray-200">
  <div class="mx-auto max-w-6xl px-6 py-12 lg:px-8">
    <div class="flex flex-col gap-8 md:flex-row md:items-center md:justify-between">
      <div class="flex flex-col gap-4">
        <h3 class="text-2xl font-bold text-gray-800">{siteConfig.name}</h3>
        <p class="text-base text-gray-600">{siteConfig.title}</p>
        <p class="max-w-xl text-sm leading-relaxed text-gray-500">
          Experience across whole-body control, embodied navigation, and world-model-oriented robotics systems. Currently seeking remote research internship opportunities.
        </p>
        <div class="flex flex-wrap gap-3 text-sm text-gray-600">
          <a href={`mailto:${siteConfig.social.email}`} class="hover:text-gray-900 transition-colors">{siteConfig.social.email}</a>
          {
            siteConfig.social?.emailSecondary && (
              <a href={`mailto:${siteConfig.social.emailSecondary}`} class="hover:text-gray-900 transition-colors">
                {siteConfig.social.emailSecondary}
              </a>
            )
          }
        </div>
      </div>
      <div class="flex items-center gap-5 text-sm font-medium text-gray-600">
        <a href={`mailto:${siteConfig.social.email}`} class="hover:text-gray-900 transition-colors">Email</a>
        <a href={siteConfig.social.linkedin} target="_blank" rel="noopener noreferrer" class="hover:text-gray-900 transition-colors">LinkedIn</a>
        <a href={siteConfig.social.github} target="_blank" rel="noopener noreferrer" class="hover:text-gray-900 transition-colors">GitHub</a>
        <a href={siteConfig.social.cv} class="hover:text-gray-900 transition-colors">CV</a>
      </div>
    </div>
  </div>
</footer>
