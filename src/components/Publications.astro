---
import { siteConfig } from "../config";
const hasPublications =
  siteConfig.publications && siteConfig.publications.length > 0;
---

{
  hasPublications && (
    <section id="publications" class="p-8 sm:p-12 md:p-16 lg:p-24">
      <div>
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-16 items-start">
          <div class="lg:col-span-4">
            <h2 class="text-3xl sm:text-4xl md:text-5xl xl:text-7xl font-bold text-gray-900">
              Publications
            </h2>
            <div
              class="w-[75px] h-[5px] mt-2 rounded-full"
              style={`background-color: ${siteConfig.accentColor}`}
            />
          </div>

          <div class="lg:col-span-8">
            <div class="space-y-6">
              {siteConfig.publications.map((pub) => (
                <div class="rounded-xl border border-gray-200 bg-white p-5 sm:p-6 md:p-7 shadow-sm transition-shadow duration-300 hover:shadow-md">
                  <div class="space-y-2">
                    <p
                      class="text-sm font-mono"
                      style={{ color: siteConfig.accentColor }}
                    >
                      {pub.venue} | {pub.note}
                    </p>
                    <h3 class="text-lg sm:text-xl font-semibold text-gray-900">
                      {pub.title}
                    </h3>
                    <p class="text-sm sm:text-base text-gray-600 leading-relaxed">
                      {pub.summary}
                    </p>
                  </div>
                </div>
              ))}
            </div>
            <p class="mt-6 text-sm text-gray-500">
              Additional manuscripts, project details, and materials are available upon request.
            </p>
          </div>
        </div>
      </div>
    </section>
  )
}
