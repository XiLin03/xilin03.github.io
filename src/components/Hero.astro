---
import { siteConfig } from "../config";
---

<div
  id="hero"
  class="relative isolate overflow-hidden bg-white py-24 md:min-h-screen"
  style={`--accent-color: ${siteConfig.accentColor}`}
>
  <div class="absolute inset-0 -z-10 bg-white"></div>
  <div
    class="absolute -left-40 top-1/2 -z-10 h-[42rem] w-[42rem] -translate-y-1/2 rounded-full blur-3xl"
    style={`background: radial-gradient(circle, ${siteConfig.accentColor}26 0%, ${siteConfig.accentColor}16 30%, rgba(219, 234, 254, 0.32) 52%, transparent 76%)`}
  ></div>
  <div
    class="absolute left-0 top-0 -z-10 h-full w-[36rem]"
    style={`background: linear-gradient(90deg, ${siteConfig.accentColor}12 0%, ${siteConfig.accentColor}08 28%, transparent 82%)`}
  ></div>
  <div
    class="absolute right-[-10rem] top-20 -z-10 h-[24rem] w-[24rem] rounded-full blur-3xl"
    style={`background: radial-gradient(circle, ${siteConfig.accentColor}14 0%, rgba(191, 219, 254, 0.15) 38%, transparent 72%)`}
  ></div>
  <svg
    aria-hidden="true"
    class="absolute inset-0 -z-10 size-full stroke-gray-200 [mask-image:radial-gradient(100%_100%_at_top_right,white,transparent)]"
  >
    <defs>
      <pattern
        x="50%"
        y={-1}
        id="hero-grid"
        width={200}
        height={200}
        patternUnits="userSpaceOnUse"
      >
        <path d="M.5 200V.5H200" fill="none"></path>
      </pattern>
    </defs>
    <rect fill="url(#hero-grid)" width="100%" height="100%" stroke-width={0}></rect>
  </svg>
  <div class="mx-auto flex min-h-[78vh] items-center p-8 sm:p-12 md:p-24">
    <div>
      <h1
        class="text-pretty text-[clamp(4.5rem,13vw,10rem)] font-bold leading-[0.92] tracking-[-0.06em] text-gray-800 animate-fade-in"
      >
        <span style={{ color: siteConfig.accentColor }}>{siteConfig.name}</span>
      </h1>
      <p
        class="mt-6 text-pretty text-2xl sm:text-3xl md:text-4xl font-medium text-gray-600 animate-fade-in animation-delay-200"
      >
        {siteConfig.title}
      </p>
      <p
        class="mt-8 max-w-3xl text-lg sm:text-xl leading-relaxed text-gray-500 animate-fade-in animation-delay-400"
      >
        {siteConfig.heroInterestsText}
      </p>
      <p
        class="mt-3 max-w-3xl text-lg sm:text-xl leading-relaxed text-gray-500 animate-fade-in animation-delay-400"
      >
        {siteConfig.heroStatusText}
      </p>
      <div class="mt-8 flex flex-wrap gap-4 animate-fade-in animation-delay-600">
        <a
          href={siteConfig.social.cv}
          class="inline-flex items-center rounded-full bg-gray-900 px-6 py-3 text-sm font-semibold text-white transition hover:bg-gray-700"
        >
          Download CV
        </a>
        <a
          href={siteConfig.social.cvCn}
          class="inline-flex items-center rounded-full border border-gray-300 px-6 py-3 text-sm font-semibold text-gray-700 transition hover:border-gray-900 hover:text-gray-900"
        >
          CV (CN)
        </a>
        <a
          href={`mailto:${siteConfig.social.email}`}
          class="inline-flex items-center rounded-full border border-gray-300 px-6 py-3 text-sm font-semibold text-gray-700 transition hover:border-gray-900 hover:text-gray-900"
        >
          Contact
        </a>
      </div>
    </div>
  </div>
  <div
    class="absolute bottom-0 left-0 right-0 p-8 sm:p-12 md:p-24 flex gap-x-4 sm:gap-x-6 md:gap-x-8 text-gray-700 animate-fade-in animation-delay-600"
  >
    {
      siteConfig.social?.email && (
        <a
          href={`mailto:${siteConfig.social.email}`}
          aria-label="Email"
          class="transition-colors duration-300 hover:text-[var(--accent-color)]"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-6 w-6 sm:h-7 sm:w-7 md:h-8 md:w-8"><path stroke="none" d="M0 0h24v24H0z" fill="none" /><path d="M3 7a2 2 0 0 1 2 -2h14a2 2 0 0 1 2 2v10a2 2 0 0 1 -2 2h-14a2 2 0 0 1 -2 -2v-10z" /><path d="M3 7l9 6l9 -6" /></svg>
        </a>
      )
    }
    {
      siteConfig.social?.emailSecondary && (
        <a
          href={`mailto:${siteConfig.social.emailSecondary}`}
          aria-label="Secondary Email"
          class="text-sm font-semibold transition-colors duration-300 hover:text-[var(--accent-color)] md:text-base"
        >
          Outlook
        </a>
      )
    }
    {
      siteConfig.social?.linkedin && (
        <a
          href={siteConfig.social.linkedin}
          target="_blank"
          rel="noopener noreferrer"
          aria-label="LinkedIn"
          class="transition-colors duration-300 hover:text-[var(--accent-color)]"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-6 w-6 sm:h-7 sm:w-7 md:h-8 md:w-8"><path stroke="none" d="M0 0h24v24H0z" fill="none" /><path d="M8 11v5" /><path d="M8 8v.01" /><path d="M12 16v-5" /><path d="M16 16v-3a2 2 0 1 0 -4 0" /><path d="M3 7a4 4 0 0 1 4 -4h10a4 4 0 0 1 4 4v10a4 4 0 0 1 -4 4h-10a4 4 0 0 1 -4 -4z" /></svg>
        </a>
      )
    }
    {
      siteConfig.social?.github && (
        <a
          href={siteConfig.social.github}
          target="_blank"
          rel="noopener noreferrer"
          aria-label="GitHub"
          class="transition-colors duration-300 hover:text-[var(--accent-color)]"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-6 w-6 sm:h-7 sm:w-7 md:h-8 md:w-8"><path stroke="none" d="M0 0h24v24H0z" fill="none" /><path d="M9 19c-4.3 1.4 -4.3 -2.5 -6 -3m12 5v-3.5c0 -1 .1 -1.4 -.5 -2c2.8 -.3 5.5 -1.4 5.5 -6a4.6 4.6 0 0 0 -1.3 -3.2a4.2 4.2 0 0 0 -.1 -3.2s-1.1 -.3 -3.5 1.3a12.3 12.3 0 0 0 -6.2 0c-2.4 -1.6 -3.5 -1.3 -3.5 -1.3a4.2 4.2 0 0 0 -.1 3.2a4.6 4.6 0 0 0 -1.3 3.2c0 4.6 2.7 5.7 5.5 6c-.6 .6 -.6 1.2 -.5 2v3.5" /></svg>
        </a>
      )
    }
    {
      siteConfig.social?.cv && (
        <a
          href={siteConfig.social.cv}
          aria-label="CV"
          class="transition-colors duration-300 hover:text-[var(--accent-color)] text-sm font-semibold md:text-base"
        >
          CV
        </a>
      )
    }
  </div>
</div>

<style>
  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .animate-fade-in {
    animation: fadeIn 0.8s ease-out forwards;
    opacity: 0;
  }

  .animation-delay-200 {
    animation-delay: 0.2s;
  }

  .animation-delay-400 {
    animation-delay: 0.4s;
  }

  .animation-delay-600 {
    animation-delay: 0.6s;
  }
</style>
